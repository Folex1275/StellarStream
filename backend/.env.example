# Database Configuration (required for Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellarstream

# Stellar Network Configuration
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract Configuration
CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# Service Configuration
POLL_INTERVAL_MS=5000
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# Optional: Logging
LOG_LEVEL=info

# Security Configuration
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# API Documentation Configuration (optional)
API_TITLE=StellarStream API
API_VERSION=1.0.0
API_DESCRIPTION=REST API for StellarStream - A Stellar network payment streaming indexer
API_CONTACT_NAME=StellarStream Team
API_CONTACT_URL=https://github.com/stellarstream
API_LICENSE_NAME=MIT
API_LICENSE_URL=https://opensource.org/licenses/MIT
API_SERVER_URL_DEV=http://localhost:3001
API_SERVER_URL_PROD=https://api.stellarstream.io
