// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// Mirrors the Stream state from the Soroban smart contract
model Stream {
  id              String       @id // Primary Key from Contract (Contract Stream ID)
  sender          String
  receiver        String
  tokenAddress    String
  amountPerSecond BigInt
  totalAmount     BigInt
  status          StreamStatus @default(ACTIVE)

  @@index([sender])
  @@index([receiver])
}

// Deduplication: one row per Stellar event (unique event_id from RPC)
model EventLog {
  eventId   String   @id @map("event_id")
  eventType String?  @map("event_type")
  txHash    String?  @map("tx_hash")
  ledger    Int?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("event_log")
}

// Tracks the last synced blockchain ledger sequence
model SyncState {
  id                 Int @id @default(1)
  lastLedgerSequence Int @default(0)
}

// Audit log for all protocol events (full event records)
model AuditEvent {
  id              String   @id @default(cuid())
  eventType       String
  streamId        String
  txHash          String
  ledger          Int
  ledgerClosedAt  String
  sender          String?
  receiver        String?
  amount          BigInt?
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([streamId])
  @@index([eventType])
  @@index([createdAt])
  @@index([ledger])
  @@map("audit_events")
}

// Sync checkpoint for metadata indexer (singleton by id)
model SyncMetadata {
  id                 String @id
  lastLedgerSequence Int    @default(0)

  @@map("sync_metadata")
}

enum StreamStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}
